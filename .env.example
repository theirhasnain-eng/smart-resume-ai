# Neon PostgreSQL — use POOLED connection string on Vercel (host contains "-pooler")
# Create free DB: https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Random secret (32+ chars). PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="change-this-to-a-long-random-string"

# Set AFTER first Vercel deploy to your live URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional — first admin (run npm run db:seed once against Neon)
SEED_ADMIN_EMAIL="admin@smartresume.ai"
SEED_ADMIN_PASSWORD="Admin@123"
